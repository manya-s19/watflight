{
	"name": "watflight_site",
	"homepage": "https://manya-s19.github.io/watflight/",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"dev": "concurrently --kill-others --raw \"npm run dev --prefix apps/web\"",
		"build": "concurrently --raw \"npm run build --prefix apps/web\"",
		"start": "concurrently --kill-others --raw",
		"lint": "concurrently --raw \"npm run lint --prefix apps/web\"",
		"preview": "vite preview",
		"predeploy": "npm run build",
		"deploy": "gh-pages -d dist/apps/web"
	},
	"devDependencies": {
		"concurrently": "^9.1.2"
	},
	"workspaces": [
		"apps/*"
	],
	"dependencies": {
		"gh-pages": "^6.3.0"
	}
}
